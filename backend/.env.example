# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados
DATABASE_URL=postgresql://usuario:senha@localhost:5432/restaurante

# Segurança — JWT_SECRET deve ter mínimo 32 caracteres
JWT_SECRET=troque-por-uma-string-aleatoria-de-pelo-menos-32-chars

# CORS — separar múltiplas origens por vírgula
CORS_ORIGIN=http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Impressora ESC/POS (opcional)
PRINTER_ENABLED=false
PRINTER_IP=
PRINTER_PORT=9100

# WebSocket
SOCKET_PATH=/socket.io
